# AI Employee FTE - .gitignore

# ===========================================
# SECURITY - NEVER COMMIT THESE FILES
# ===========================================

# Secrets and credentials
.env
*.env
credentials.json
token.json
token.pickle
.secrets/
whatsapp-session/
linkedin-session/
facebook-session/

# OAuth tokens
*.pem
*.key
*.crt

# ===========================================
# Python
# ===========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Translations
*.mo
*.pot

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# Environments
venv/
ENV/
env/
.venv

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# ===========================================
# Node.js (for MCP servers)
# ===========================================

node_modules/
npm-debug.log
yarn-error.log

# ===========================================
# Logs and Databases
# ===========================================

# Logs
Logs/
*.log
database.log

# Database
*.db
*.sqlite
*.sqlite3

# ===========================================
# Operating System
# ===========================================

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ===========================================
# Temporary Files
# ===========================================

tmp/
temp/
*.tmp
*.bak
*.swp

# ===========================================
# Documentation (Optional)
# ===========================================

# Large media files
*.mp4
*.mov
*.avi
*.png
*.jpg
*.jpeg

# ===========================================
# Build Outputs
# ===========================================

build/
dist/
*.egg-info/

# ===========================================
# Project Specific
# ===========================================

# Odoo data (if local)
odoo/data/

# Vault state files (optional)
AI_Employee_Vault/Plans/*.md
AI_Employee_Vault/Briefings/*.md

# Keep these folders but ignore contents
AI_Employee_Vault/Inbox/*
AI_Employee_Vault/Needs_Action/*
AI_Employee_Vault/Done/*
AI_Employee_Vault/Approved/*
AI_Employee_Vault/Pending_Approval/*
AI_Employee_Vault/Rejected/*

# But keep the folder structure
!AI_Employee_Vault/Inbox/.gitkeep
!AI_Employee_Vault/Needs_Action/.gitkeep
!AI_Employee_Vault/Done/.gitkeep
!AI_Employee_Vault/Approved/.gitkeep
!AI_Employee_Vault/Pending_Approval/.gitkeep
!AI_Employee_Vault/Rejected/.gitkeep
